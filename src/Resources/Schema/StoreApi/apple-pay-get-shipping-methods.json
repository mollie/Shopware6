{
  "openapi": "3.0.3",
  "info": {
    "title": "Apple Pay Shipping Methods Endpoint",
    "description": "Endpoint to retrieve shipping methods for Apple Pay integration.",
    "version": "1.0.0"
  },
  "paths": {
    "/mollie/applepay/shipping-methods": {
      "post": {
        "tags": [
          "Mollie",
          "ApplePay"
        ],
        "summary": "Retrieve Apple Pay Shipping Methods",
        "operationId": "retrieveApplePayShippingMethods",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "countryCode": {
                    "type": "string",
                    "description": "The country code for which shipping methods are requested."
                  }
                },
                "required": ["countryCode"],
                "example": {
                  "countryCode": "NL"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Apple Pay shipping methods response. The selected shipping method is always the first element.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "shippingMethods": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "identifier": {
                            "type": "string",
                            "description": "The shipping method ID."
                          },
                          "label": {
                            "type": "string",
                            "description": "The shipping method name."
                          },
                          "detail": {
                            "type": "string",
                            "description": "The delivery time name, or an empty string."
                          },
                          "amount": {
                            "type": "number",
                            "format": "float",
                            "description": "The shipping cost for this method."
                          }
                        },
                        "required": ["identifier", "label", "detail", "amount"]
                      }
                    },
                    "apiAlias": {
                      "type": "string",
                      "example": "mollie_payments_applepay_direct_shipping_methods"
                    }
                  },
                  "required": ["shippingMethods", "apiAlias"]
                },
                "example": {
                  "shippingMethods": [
                    {
                      "identifier": "a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4",
                      "label": "Standard Shipping",
                      "detail": "Delivers within 3-5 business days",
                      "amount": 5.99
                    },
                    {
                      "identifier": "f6e5d4c3b2a1f6e5d4c3b2a1f6e5d4c3",
                      "label": "Express Shipping",
                      "detail": "Delivers within 1-2 business days",
                      "amount": 12.99
                    }
                  ],
                  "apiAlias": "mollie_payments_applepay_direct_shipping_methods"
                }
              }
            }
          }
        }
      }
    }
  }
}
