{
  "openapi": "3.0.3",
  "info": {
    "title": "Apple Pay Enabled Endpoint",
    "description": "Endpoint to check if Apple Pay integration is enabled.",
    "version": "1.0.0"
  },
  "paths": {
    "/mollie/applepay/enabled": {
      "get": {
        "tags": [
          "Mollie",
          "ApplePay"
        ],
        "summary": "Check Apple Pay Integration Enabled Status",
        "operationId": "checkApplePayEnabled",
        "responses": {
          "200": {
            "description": "Apple Pay integration status.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "example": true,
                      "description": "Indicates if Apple Pay Direct is enabled."
                    },
                    "paymentMethodId": {
                      "type": "string",
                      "nullable": true,
                      "description": "The Apple Pay payment method ID, or null if the payment method does not exist."
                    },
                    "apiAlias": {
                      "type": "string",
                      "example": "mollie_payments_applepay_direct_enabled"
                    }
                  },
                  "required": ["enabled", "paymentMethodId", "apiAlias"]
                },
                "example": {
                  "enabled": true,
                  "paymentMethodId": "a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4",
                  "apiAlias": "mollie_payments_applepay_direct_enabled"
                }
              }
            }
          }
        }
      }
    }
  }
}
