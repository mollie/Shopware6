{
  "openapi": "3.0.3",
  "info": {
    "title": "Apple Pay ID Endpoint",
    "description": "Endpoint to retrieve Apple Pay ID.",
    "version": "1.0.0"
  },
  "paths": {
    "/mollie/applepay/id": {
      "get": {
        "tags": [
          "Mollie",
          "ApplePay"
        ],
        "summary": "Retrieve Apple Pay ID",
        "operationId": "retrieveApplePayId",
        "responses": {
          "200": {
            "description": "Apple Pay ID retrieval response.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true,
                      "description": "True when an Apple Pay payment method ID was found."
                    },
                    "id": {
                      "type": "string",
                      "nullable": true,
                      "example": "a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4",
                      "description": "The Apple Pay payment method ID, or null if not found."
                    },
                    "apiAlias": {
                      "type": "string",
                      "example": "mollie_payments_applepay_direct_id"
                    }
                  },
                  "required": ["success", "id", "apiAlias"]
                },
                "example": {
                  "success": true,
                  "id": "a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4",
                  "apiAlias": "mollie_payments_applepay_direct_id"
                }
              }
            }
          }
        }
      }
    }
  }
}
