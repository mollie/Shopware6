{
  "openapi": "3.0.3",
  "info": {
    "title": "Apple Pay Pay Endpoint",
    "description": "Endpoint to initiate a payment with Apple Pay integration.",
    "version": "1.0.0"
  },
  "paths": {
    "/mollie/applepay/pay": {
      "post": {
        "tags": [
          "Mollie",
          "ApplePay"
        ],
        "summary": "Initiate Apple Pay Payment",
        "operationId": "initiateApplePayPayment",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "paymentToken": {
                    "type": "string",
                    "description": "The Apple Pay payment token. This is the only required field."
                  },
                  "email": {
                    "type": "string",
                    "description": "The email of the customer."
                  },
                  "firstname": {
                    "type": "string",
                    "description": "The firstname of the customer."
                  },
                  "lastname": {
                    "type": "string",
                    "description": "The lastname of the customer."
                  },
                  "street": {
                    "type": "string",
                    "description": "The street address of the customer."
                  },
                  "city": {
                    "type": "string",
                    "description": "The city of the customer."
                  },
                  "postalCode": {
                    "type": "string",
                    "description": "The postal code of the customer."
                  },
                  "countryCode": {
                    "type": "string",
                    "description": "The country code of the customer."
                  },
                  "phone": {
                    "type": "string",
                    "description": "The phone number of the customer (optional)."
                  },
                  "acceptedDataProtection": {
                    "type": "integer",
                    "description": "Whether the customer accepted the data protection terms (0 or 1).",
                    "example": 1
                  }
                },
                "required": ["paymentToken"],
                "example": {
                  "paymentToken": "applepay_payment_token_123",
                  "email": "john.doe@example.com",
                  "firstname": "John",
                  "lastname": "Doe",
                  "street": "123 Apple Pay St",
                  "city": "Apple City",
                  "postalCode": "12345",
                  "countryCode": "US",
                  "phone": "+1 555 0100",
                  "acceptedDataProtection": 1
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success response with payment details.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true,
                      "description": "Always true on success."
                    },
                    "url": {
                      "type": "string",
                      "description": "The redirect URL returned by the payment handler. May be an empty string when no redirect is required."
                    },
                    "message": {
                      "type": "string",
                      "description": "Additional message. Always an empty string on success."
                    },
                    "orderId": {
                      "type": "string",
                      "description": "The ID of the created Shopware order."
                    },
                    "apiAlias": {
                      "type": "string",
                      "example": "mollie_payments_applepay_direct_payment"
                    }
                  },
                  "required": ["success", "url", "message", "orderId", "apiAlias"]
                },
                "example": {
                  "success": true,
                  "url": "https://applepay.mollie.com/redirect",
                  "message": "",
                  "orderId": "a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4",
                  "apiAlias": "mollie_payments_applepay_direct_payment"
                }
              }
            }
          }
        }
      }
    }
  }
}
