{
  "openapi": "3.0.3",
  "info": {
    "title": "Mollie Subscription Webhook Endpoint",
    "description": "Endpoint Mollie calls to notify the shop about subscription payment events. Either updates the matching order transaction or renews the subscription.",
    "version": "1.0.0"
  },
  "paths": {
    "/mollie/webhook/subscription/{subscriptionId}": {
      "get": {
        "tags": [
          "Mollie",
          "Webhook"
        ],
        "summary": "Handle Mollie Subscription Webhook (GET)",
        "operationId": "handleMollieSubscriptionWebhookGet",
        "parameters": [
          {
            "name": "subscriptionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The Mollie subscription ID."
          }
        ],
        "responses": {
          "200": {
            "description": "Mollie subscription webhook handled successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "success",
                      "description": "Indicates the webhook was processed successfully."
                    },
                    "payment": {
                      "type": "object",
                      "description": "The processed Mollie payment.",
                      "additionalProperties": true
                    },
                    "apiAlias": {
                      "type": "string",
                      "example": "webhook.route.success"
                    }
                  },
                  "required": ["status"]
                }
              }
            }
          },
          "422": {
            "description": "Failed to handle Mollie subscription webhook. The status code mirrors the thrown ShopwareHttpException, defaulting to 422 for unexpected errors.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": false,
                      "description": "Indicates the webhook processing failed."
                    },
                    "error": {
                      "type": "string",
                      "example": "Invalid subscription webhook data.",
                      "description": "Error message describing the reason for failure."
                    }
                  },
                  "required": ["success", "error"]
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Mollie",
          "Webhook"
        ],
        "summary": "Handle Mollie Subscription Webhook (POST)",
        "operationId": "handleMollieSubscriptionWebhookPost",
        "parameters": [
          {
            "name": "subscriptionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The Mollie subscription ID."
          }
        ],
        "responses": {
          "200": {
            "description": "Mollie subscription webhook handled successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "success",
                      "description": "Indicates the webhook was processed successfully."
                    },
                    "payment": {
                      "type": "object",
                      "description": "The processed Mollie payment.",
                      "additionalProperties": true
                    },
                    "apiAlias": {
                      "type": "string",
                      "example": "webhook.route.success"
                    }
                  },
                  "required": ["status"]
                }
              }
            }
          },
          "422": {
            "description": "Failed to handle Mollie subscription webhook. The status code mirrors the thrown ShopwareHttpException, defaulting to 422 for unexpected errors.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": false,
                      "description": "Indicates the webhook processing failed."
                    },
                    "error": {
                      "type": "string",
                      "example": "Invalid subscription webhook data.",
                      "description": "Error message describing the reason for failure."
                    }
                  },
                  "required": ["success", "error"]
                }
              }
            }
          }
        }
      }
    }
  }
}
