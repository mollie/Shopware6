{
  "openapi": "3.0.3",
  "info": {
    "title": "Mollie Subscription Webhook Endpoint",
    "description": "Endpoint for handling Mollie subscription webhook notifications.",
    "version": "1.0.0"
  },
  "paths": {
    "/mollie/webhook/subscription/{subscriptionId}": {
      "get": {
        "summary": "Handle Mollie Subscription Webhook Notification (GET)",
        "tags": ["Mollie"],
        "operationId": "handleMollieSubscriptionWebhookGet",
        "parameters": [
          {
            "name": "subscriptionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The Shopware ID of the subscription associated with the webhook."
          },
          {
            "name": "id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The ID of the Mollie payment that triggered the webhook."
          }
        ],
        "responses": {
          "200": {
            "description": "Webhook handled successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WebhookResponse"
                },
                "example": {
                  "payment": {
                    "id": "tr_123456789"
                  },
                  "status": "success"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Handle Mollie Subscription Webhook Notification (POST)",
        "tags": ["Mollie"],
        "operationId": "handleMollieSubscriptionWebhookPost",
        "parameters": [
          {
            "name": "subscriptionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The Shopware ID of the subscription associated with the webhook."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string",
                    "description": "The ID of the Mollie payment that triggered the webhook."
                  }
                },
                "required": ["id"],
                "example": {
                  "id": "tr_123456789"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Webhook handled successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WebhookResponse"
                },
                "example": {
                  "payment": {
                    "id": "tr_123456789"
                  },
                  "status": "success"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "WebhookResponse": {
        "type": "object",
        "properties": {
          "payment": {
            "type": "object",
            "description": "The Mollie payment associated with the transaction."
          },
          "status": {
            "type": "string",
            "example": "success"
          }
        },
        "required": ["payment", "status"]
      }
    }
  }
}
