{% sw_extends '@Storefront/storefront/component/line-item/type/product.html.twig' %}


{% block component_line_item_type_product_order_number %}
    {{ parent() }}
    {% if lineItem.extensions.mollie_payments and lineItem.extensions.mollie_payments.subscription %}
        <div class="line-item-ordernumber">
            {{ lineItem.extensions.mollie_payments|mollie_subscription_interval }}
        </div>
    {% endif %}
{% endblock %}

{% block component_line_item_type_product_number %}
    {{ parent() }}
    {% if lineItem.extensions.mollie_payments and lineItem.extensions.mollie_payments.subscription %}
        <div class="line-item-product-number">
            {{ lineItem.extensions.mollie_payments|mollie_subscription_interval }}
        </div>
    {% endif %}
{% endblock %}
