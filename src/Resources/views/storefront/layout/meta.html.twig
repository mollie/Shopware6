{% sw_extends '@Storefront/storefront/layout/meta.html.twig' %}

{% block layout_head_meta_tags %}
    {{ parent() }}
    {% block mollie_apple_pay_sdk %}
        {# Must stay in <head>: the SDK has to run before the storefront bundle inits our payment
           plugins, otherwise window.ApplePaySession is still undefined in non-Safari browsers. #}
        {% if mollie_applepaydirect_enabled is defined and mollie_applepaydirect_enabled %}
            <script crossorigin src="https://applepay.cdn-apple.com/jsapi/1.latest/apple-pay-sdk.js"></script>
        {% endif %}
    {% endblock %}
{% endblock %}
