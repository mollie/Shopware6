<?xml version="1.0" encoding="UTF-8" ?>
<routes xmlns="http://symfony.com/schema/routing"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://symfony.com/schema/routing
        https://symfony.com/schema/routing/routing-1.0.xsd">

    <route id="frontend.account.mollie.mandates.page"
           path="/account/mollie/mandates"
           methods="GET|POST">
        <default key="_controller">Kiener\MolliePayments\Controller\Storefront\Account\AccountControllerBase::mandatesList</default>
        <default key="_routeScope"><list><string>storefront</string></list></default>
        <default key="XmlHttpRequest"><bool>true</bool></default>
        <option key="seo">false</option>
    </route>


</routes>
