<?xml version="1.0" encoding="UTF-8" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services
        https://symfony.com/schema/dic/services/services-1.0.xsd">

    <imports>
        <import resource="packages/**/*.xml"/>
    </imports>

    <services>
        <defaults autowire="true" autoconfigure="true"/>

        <prototype namespace="Mollie\Shopware\" resource="./../../../shopware/" exclude="../../../shopware/{Resources,Migration,*.php}"/>

        <service id="Monolog\Processor\WebProcessor">
            <tag name="monolog.processor" channel="mollie"/>
        </service>

        <service id="Monolog\Processor\IntrospectionProcessor">
            <tag name="monolog.processor" channel="mollie"/>
        </service>

    </services>

</container>
