export default "{% block sw_order_list_grid_columns %}\n    {% parent %}\n    {% block sw_order_list_grid_columns_mollie_abo %}\n        <template #column-mollie=\"{ item }\">\n            <sw-label v-if=\"isMollie(item)\"\n                      variant=\"ghost\"\n                      size=\"default\"\n                      appearance=\"pill\"\n                      :ghost=\"false\"\n                      :caps=\"false\"\n                      :dismissable=\"false\">\n                {{ getMollieId(item) }}\n            </sw-label>\n            <sw-label v-if=\"isMollieSubscription(item)\"\n                      variant=\"info\"\n                      size=\"default\"\n                      appearance=\"pill\"\n                      :ghost=\"false\"\n                      :caps=\"false\"\n                      :dismissable=\"false\">\n                {{ $tc('mollie-payments.sw-order-list.badgeSubscription') }}\n            </sw-label>\n        </template>\n    {% endblock %}\n{% endblock %}";