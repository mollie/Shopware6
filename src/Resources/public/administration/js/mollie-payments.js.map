export default "<sw-card\n        :title=\"$tc('mollie-payments.subscriptions.navigation.title')\"\n        class=\"sw-customer-mollie-subscriptions\"\n        large=\"true\"\n>\n\n    <sw-loader\n            v-if=\"isLoading\"\n            size=\"16px\"\n    />\n\n    <sw-data-grid\n            v-if=\"subscriptions.length > 0\"\n            :data-source=\"subscriptions\"\n            :columns=\"columns\"\n            :show-selection=\"false\"\n            :is-loading=\"isLoading\"\n    >\n\n        <template #column-status=\"{ item }\">\n            <sw-label :variant=\"statusColor(item.status)\"\n                      size=\"medium\"\n                      appearance=\"pill\"\n                      :ghost=\"false\"\n                      :caps=\"true\"\n                      :dismissable=\"false\">\n                {{ item.status }}\n            </sw-label>\n        </template>\n\n        <template #column-amount=\"{ item }\">\n            {{ item.amount.value }} {{ item.amount.currency }}\n        </template>\n\n        <template #actions=\"{ item }\">\n\n            <sw-context-menu-item\n                    variant=\"danger\"\n                    :disabled=\"item.status !== 'active'\"\n                    @click=\"cancelSubscription(item)\"\n            >\n                {{ $tc('mollie-payments.subscriptions.detail.buttonCancelSubscription') }}\n            </sw-context-menu-item>\n\n        </template>\n\n    </sw-data-grid>\n    <sw-empty-state\n            v-else\n            :absolute=\"false\"\n            :title=\"$tc('sw-empty-state.messageNoResultTitle')\"\n    >\n    </sw-empty-state>\n</sw-card>\n\n\n\n";